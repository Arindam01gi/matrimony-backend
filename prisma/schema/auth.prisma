model User {
    id                  String      @id @default(uuid())
    firstName           String 
    lastName            String
    email               String?     @unique
    phone               String?     @unique
    passwordWithHash    String      
    isVerified          Boolean     @default(false)
    createdAt           DateTime    @default(now())
    updatedAt           DateTime    @default(now())


    @@index([email, phone])

}