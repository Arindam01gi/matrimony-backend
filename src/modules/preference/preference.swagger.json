{
  "paths": {
    "/api/v1/preference/save": {
      "post": {
        "summary": "Save or update partner preferences dynamically",
        "description": "Exposes a dynamic single gateway endpoint for all preference wizard steps. If settings do not exist, it runs an insert. If they exist, it runs a delta update patching only the fields provided.",
        "tags": ["Partner Preference"],
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "minAge": { "type": "integer", "example": 22 },
                  "maxAge": { "type": "integer", "example": 28 },
                  "minHeight": { "type": "number", "example": 5.2 },
                  "maxHeight": { "type": "number", "example": 5.8 },
                  "gender": { "type": "string", "enum": ["MALE", "FEMALE"], "example": "FEMALE" },
                  "maritalStatus": { "type": "array", "items": { "type": "string" }, "example": ["UNMARRIED"] },
                  "religion": { "type": "array", "items": { "type": "string" }, "example": ["HINDU"] },
                  "caste": { "type": "array", "items": { "type": "string" }, "example": ["Brahmin", "Kayastha"] },
                  "motherTongue": { "type": "array", "items": { "type": "string" }, "example": ["Bengali"] },
                  "district": { "type": "array", "items": { "type": "string" }, "example": ["Kolkata", "24 Parganas North"] }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Preferences saved successfully",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Partner preferences saved successfully." }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/preference/me": {
      "get": {
        "summary": "Fetch current user's partner preferences",
        "tags": ["Partner Preference"],
        "security": [{ "bearerAuth": [] }],
        "responses": {
          "200": {
            "description": "Preferences retrieved successfully"
          }
        }
      }
    }
  }
}