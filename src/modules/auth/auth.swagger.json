{
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new Bengali Matrimony user account",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["firstName", "lastName", "password"],
                "properties": {
                  "firstName": { "type": "string", "example": "Arindam" },
                  "lastName": { "type": "string", "example": "Chatterjee" },
                  "email": { "type": "string", "format": "email", "example": "arindam@yopmail.com" },
                  "phone": { "type": "string", "example": "9876543210" },
                  "password": { "type": "string", "minLength": 6, "example": "Password@123" }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created successfully and authenticated session initialized"
          },
          "400": {
            "description": "Validation error or user already exists"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login via Email or Phone split inputs",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": { "type": "string", "format": "email", "example": "arindam@yopmail.com" },
                  "phone": { "type": "string", "example": "9876543210" },
                  "password": { "type": "string", "example": "Password@123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User authenticated successfully and tracking session initialized",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "User authenticated successfully" },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid", "example": "94346614-e045-4fd8-8a4c-1ff4844dfbfe" },
                        "email": { "type": "string", "format": "email", "example": "arindam@yopmail.com" },
                        "phone": { "type": "string", "example": "9876543210" },
                        "isVerified": { "type": "boolean", "example": false },
                        "createdAt": { "type": "string", "format": "date-time", "example": "2026-06-10T01:59:15.014Z" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": { "description": "Invalid credentials" }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "summary": "Rotate expired session token using secure HTTP-Only cookie",
        "description": "Exchanges a valid long-lived background `refreshToken` cookie for a new short-lived frontend `accessToken`. The browser sends this cookie automatically if configured correctly via credentials.",
        "tags": ["Authentication"],
        "parameters": [
          {
            "in": "cookie",
            "name": "refreshToken",
            "required": true,
            "description": "The secure HttpOnly session validation string token automatically passed by the browser.",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Token rotated successfully. Access token renewed.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Token rotated successfully" },
                    "accessToken": { 
                      "type": "string", 
                      "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI5NDM0NjYxNC1lMDQ1LTRmZDgtOGE0Yy0xZmY0ODQ0ZGZiZmUifQ..." 
                    },
                    "user": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid", "example": "94346614-e045-4fd8-8a4c-1ff4844dfbfe" }
                      }
                    }
                  }
                }
              }
            }
          },
          "401": {
            "description": "Refresh token missing from request cookie layout",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": false },
                    "message": { "type": "string", "example": "Refresh token missing" }
                  }
                }
              }
            }
          },
          "403": {
            "description": "Refresh token is invalid, corrupted, or expired",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": false },
                    "message": { "type": "string", "example": "Invalid or expired refresh token" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Log out the current user and clear session cookies",
        "tags": ["Authentication"],
        "responses": {
          "200": {
            "description": "Cookie successfully destroyed and session cleared",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean", "example": true },
                    "message": { "type": "string", "example": "Logged out successfully" }
                  }
                }
              }
            }
          }
        }
      }
    }
    
  }
}